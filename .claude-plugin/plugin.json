{
  "name": "super-hype-harness",
  "description": "Long-running app development harness: Planner → Generator → Evaluator with file-based handoff. No sprints — build everything, then QA.",
  "version": "0.4.0",
  "author": {
    "name": "jaewon"
  },
  "repository": "https://github.com/jae1jeong/super-hype-harness",
  "license": "MIT",
  "keywords": ["harness", "pipeline", "long-running", "generator", "evaluator", "file-handoff"],
  "hooks": {
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/stop-failure-handler.sh"
          }
        ]
      }
    ]
  }
}
